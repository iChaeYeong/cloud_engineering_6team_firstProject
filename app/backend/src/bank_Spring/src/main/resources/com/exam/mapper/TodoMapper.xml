<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.mapper.TodoMapper">

    <select id="findAll" resultType="TodoDTO">
            select id, name, job
            from todo
    </select>
        <select id="findById" resultType="TodoDTO"
                parameterType="int">
        select id, name, job
        from todo
        where id=#{id}
    </select>
    <insert id="save" parameterType="TodoDTO">
        insert into todo ( id, name, job )
        values (#{id}, #{name}, #{job} )
    </insert>
    <update id="updateById" parameterType="TodoDTO">
        update todo
        set name = #{name}, job = #{job}
        where id=#{id}
    </update>
    <delete id="deleteById" parameterType="int">
        delete from todo
        where id=#{id}
    </delete>
</mapper>
